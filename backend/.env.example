APP_NAME=Smart Campus API
APP_VERSION=0.1.0
ENVIRONMENT=local

AWS_REGION=ap-southeast-1

# DynamoDB Tables
USERS_TABLE=smart-campus-users
FACES_TABLE=smart-campus-faces
ATTENDANCE_TABLE=smart-campus-attendance
SECURITY_TABLE=smart-campus-security
NOTIFICATIONS_TABLE=smart-campus-notifications

# Rekognition
FACE_COLLECTION_ID=smart-campus-faces

# S3
IMAGE_BUCKET=smart-campus-images
DATA_LAKE_BUCKET=smart-campus-datalake

# EventBridge
EVENT_BUS_NAME=smart-campus-events

# Amazon Cognito (Workflow 1 – Authentication)
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_REGION=ap-southeast-1

# SNS (Workflow 4 – Notification & Workflow 7 – Security)
SECURITY_ALERT_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789012:smart-campus-security
NOTIFICATION_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789012:smart-campus-notifications

# Amazon Bedrock (Workflow 6 – AI Assistant)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Athena (Workflow 5 – Analytics Phase 2, để trống nếu chưa setup)
ATHENA_DATABASE=smart_campus_db
ATHENA_OUTPUT_LOCATION=